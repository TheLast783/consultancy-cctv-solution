# Example Environment File - Rename to .env and fill in your actual stream & credentials

# RTSP Camera Streams (Comma-separated or newline-separated rtsp:// URLs)
RTSP_URL=rtsp://admin:password@192.168.1.2:554/cam/realmonitor?channel=1&subtype=0

# Mailer Alert Configuration
SENDER_EMAIL=your_sender_email@gmail.com
SENDER_PASSWORD=your_app_password
RECEIVER_EMAIL=your_receiver_email@gmail.com

# Ollama VLM Configuration
OLLAMA_URL=http://localhost:11434/api/generate
VLM_MODEL_NAME=llava
DB_PATH=sleep_monitor.db
